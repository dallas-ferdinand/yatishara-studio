{
  "name": "yatishara-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/studio-mcp"
  ],
  "scripts": {
    "dev": "concurrently -n convex,next -c blue,green \"npm run dev:convex\" \"npm run dev:next\"",
    "dev:next": "next dev",
    "dev:convex": "npx convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "export": "next build",
    "check:perf-budgets": "node scripts/check-perf-budgets.mjs",
    "check:launch-env": "node scripts/check-launch-env.mjs",
    "check:launch-env:convex": "node scripts/check-launch-env.mjs --convex",
    "generate:studio-light-wallpapers": "node scripts/generate-studio-light-wallpapers.mjs",
    "generate:studio-light-wallpapers:procedural": "node scripts/generate-studio-light-wallpapers.mjs",
    "process:studio-light-wallpapers": "node scripts/process-studio-light-wallpapers.mjs",
    "generate:family-wallpapers": "node scripts/generate-studio-family-wallpapers.mjs",
    "bootstrap:wallpaper-families": "node scripts/bootstrap-wallpaper-families.mjs",
    "mobile:sync": "npm --prefix mobile run sync",
    "mobile:apk": "npm --prefix mobile run build:apk"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^4.0.11",
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.92",
    "@motionone/dom": "^10.18.0",
    "@oslojs/crypto": "^1.0.1",
    "ai": "^7.0.14",
    "convex": "^1.39.1",
    "convex-helpers": "^0.1.118",
    "dompurify": "^3.2.4",
    "fflate": "^0.8.3",
    "katex": "^0.16.22",
    "lucia": "^3.2.2",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.12.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^2.1.7",
    "resend": "^6.16.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.54",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
