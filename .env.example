AI_GATEWAY_API_KEY=
GATEWAY_TEXT_MODEL_ID=google/gemini-2.5-flash-lite
# Multimodal Assistance agent (vision over product/refs).
GATEWAY_ASSISTANT_MODEL_ID=google/gemini-3-flash
# Studio mic → Deepgram (Convex voiceActions.transcribe)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en
GATEWAY_IMAGE_MODEL_ID=openai/gpt-image-2
GATEWAY_VIDEO_MODEL_ID=bytedance/seedance-2.0
# Studio Assistance co-pilot (image/video/script/element). Set 0/false to hide.
GUIDED_VIDEO_ASSISTANCE_ENABLED=1

BUNNY_STORAGE_ZONE=studio-assets
BUNNY_STORAGE_REGION=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_PULL_ZONE_HOSTNAME=
BUNNY_CDN_SIGNING_KEY=
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_ACCESS_KEY=
# Public wallpaper CDN (no signing). Upload via: node scripts/upload-studio-wallpapers.mjs
NEXT_PUBLIC_STUDIO_BG_CDN=https://yatishara-studio-assets.b-cdn.net/studio/wallpapers/v1

WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_SUBJECT=mailto:admin@yatishara.com
# Native Android push (Convex server only). Raw or base64-encoded Firebase
# service-account JSON; never expose this through a NEXT_PUBLIC variable.
FIREBASE_SERVICE_ACCOUNT_JSON=

# PayWise Checkout (Convex server secrets — set on Convex deployment)
# Sandbox: https://sandbox-api.paywise.co  Production: https://api.paywise.co
PAYWISE_API_BASE=https://sandbox-api.paywise.co
PAYWISE_ENVIRONMENT=sandbox
PAYWISE_SUBSCRIPTION_KEY=
PAYWISE_API_KEY=
PAYWISE_PAYEE_MOBILE=
PAYWISE_ORIGIN_COUNTRY=TT
# Sandbox docs permit 127.0.0.1; production must use the deployed backend's public egress IP.
PAYWISE_IP_ADDRESS=
# Comma-separated paid status values verified from your PayWise sandbox status responses.
PAYWISE_PAID_STATUSES=
# Optional overrides; defaults are pending,processing / failed,rejected,declined / cancelled,canceled.
PAYWISE_PENDING_STATUSES=
PAYWISE_REJECTED_STATUSES=
PAYWISE_CANCELLED_STATUSES=

PREVIEW_STUDIO_PASSWORD=

# Studio MCP (agents on VPS) — create key in Studio Settings → API keys
STUDIO_API_KEY=
# Optional; defaults to NEXT_PUBLIC_CONVEX_SITE_URL or CONVEX_SITE_URL
STUDIO_API_URL=
