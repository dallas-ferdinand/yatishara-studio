{
  "name": "@yatishara/studio-mcp",
  "version": "0.2.5",
  "description": "MCP server for Yatishara Studio — folders, generation, documents, and elements",
  "type": "module",
  "bin": {
    "studio-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild \"src/**/*.ts\" --outdir=dist --platform=node --format=esm --log-level=warning",
    "build:tsc": "tsc",
    "start": "node dist/index.js",
    "dev": "esbuild \"src/**/*.ts\" --outdir=dist --platform=node --format=esm --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
